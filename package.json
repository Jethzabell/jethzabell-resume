{
  "name": "jethzabell-resume",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Jethzabell Medina's professional resume website built with SvelteKit, Tailwind CSS, and DaisyUI",
  "homepage": "https://jethzabell.github.io/jethzabell-resume",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "daisyui": "^5.0.50",
    "postcss": "^8.5.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0",
    "vite": "^7.0.4"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "resume",
    "portfolio",
    "tailwindcss",
    "daisyui",
    "typescript"
  ],
  "author": "Jethzabell Medina",
  "license": "MIT"
}
